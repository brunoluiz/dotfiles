{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5-mini",
  "small_model": "github-copilot/gpt-5-mini",
  "default_agent": "github-copilot/gpt-5-mini",
  "autoupdate": true,
  "snapshot": true,
  "share": "disabled",
  "enabled_providers": [
    "github-copilot",
    "opencode",
    "llama.cpp"
  ],
  "provider": {
    // Realistically un-usable on the MacBook Air
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        // llama-server --port 8080 -m ~/.lmstudio/models/RichardErkhov/deepseek-ai_-_DeepSeek-Coder-V2-Lite-Instruct-gguf/DeepSeek-Coder-V2-Lite-Instruct.Q4_K_S.gguf -c 8192
        "deepseek-ai/DeepSeek-Coder-V2-Lite-Instruct:16b": {
          "name": "deepseek-ai/DeepSeek-Coder-V2-Lite-Instruct:16b",
          "limit": {
            "context": 8192,
            "output": 8192
          }
        }
      }
    },
  },
  "mcp": {
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": false
    },
  },
  "agent": {
    "explore": {
      "model": "github-copilot/gpt-5-mini"
    },
    "general": {
      "model": "github-copilot/gpt-5-mini"
    },
    "title": {
      "model": "github-copilot/gpt-5-mini"
    },
    "summary": {
      "model": "github-copilot/gpt-5-mini"
    },
    "compaction": {
      "model": "github-copilot/gpt-5-mini"
    },
    "plan": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "out/**",
      ".git/**",
      "vendor"
    ]
  },
}
