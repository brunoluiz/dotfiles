{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-6",
  "small_model": "anthropic/claude-sonnet-4-6",
  "autoupdate": true,
  "snapshot": true,
  "share": "disabled",
  // "enabled_providers": [
  //   "github-copilot",
  //   "opencode",
  //   "llama.cpp"
  // ],
  "plugin": [
    "@mohak34/opencode-notifier@latest"
  ],
  "mcp": {
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": false
    },
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "out/**",
      ".git/**",
      "vendor"
    ]
  },
}
